{
  "name": "opencode-nudge",
  "version": "0.2.1",
  "description": "OpenCode plugin that automatically sends a continue prompt when a session goes idle",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "nudge",
    "plugin"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bunx tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.3.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.3.3",
    "@opencode-ai/sdk": "^1.3.6",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22.0.0",
    "bun-types": "^1.3.11",
    "typescript": "^5.8.2"
  }
}
